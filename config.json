{
    "log": {
        "loglevel": "warning",
        "access": "/dev/stdout",
        "error": "/dev/stderr"
    },
    "inbounds": [{
        "tag": "VLESS_XHTTP_IN",
        "listen": "127.0.0.1",
        "port": 10000,
        "protocol": "vless",
        "settings": {
            "clients": [{
                "id": "saekaaa",
                "flow": "",
                "email": "saekaaa@ccmail.uk"
            }],
            "decryption": "none",
            "fallback": {
                "dest": 8080
            }
        },
        "streamSettings": {
            "network": "xhttp",
            "xhttpSettings": {
                "path": "/saeka",
                "mode": "packet-up",
                "xmux": {
                    "maxConcurrency": "16-32",
                    "cMaxReuseTimes": 1024,
                    "hMaxReusableSecs": "1800-3600"
                },
                "scMaxEachPostBytes": "1000000",
                "scMaxBufferedPosts": 100,
                "scStreamUpServerSecs": "20-80",
                "xPaddingBytes": "100-1000",
                "noSSEHeader": false,
                "noGRPCHeader": false
            },
            "sockopt": {
                "tcpFastOpen": true,
                "tcpNoDelay": true,
                "tcpKeepAliveIdle": 30,
                "tcpKeepAliveInterval": 15,
                "tcpKeepAliveCount": 5,
                "tcpCongestion": "bbr"
            }
        },
        "sniffing": {
            "enabled": true,
            "destOverride": ["http", "tls", "quic"],
            "metadataOnly": false,
            "routeOnly": false
        }
    }],
    "outbounds": [{
        "tag": "DIRECT",
        "protocol": "freedom",
        "settings": {},
        "streamSettings": {
            "sockopt": {
                "tcpFastOpen": true,
                "tcpNoDelay": true,
                "tcpCongestion": "bbr"
            }
        }
    }, {
        "tag": "BLOCK",
        "protocol": "blackhole",
        "settings": {}
    }],
    "routing": {
        "domainStrategy": "AsIs",
        "rules": [
            {
                "type": "field",
                "ip": ["127.0.0.0/8", "::1/128"],
                "outboundTag": "DIRECT"
            },
            {
                "type": "field",
                "protocol": ["bittorrent"],
                "outboundTag": "BLOCK"
            }
        ]
    }
}
