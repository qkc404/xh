{
    "log": {
        "loglevel": "warning",
        "access": "/dev/stdout",
        "error": "/dev/stderr"
    },
    "dns": {
        "servers": ["1.1.1.1", "8.8.8.8"],
        "queryStrategy": "UseIPv4"
    },
    "inbounds": [
        {
            "tag": "VLESS_XHTTP_IN",
            "listen": "127.0.0.1",
            "port": 10000,
            "protocol": "vless",
            "settings": {
                "clients": [
                    {
                        "id": "saekaaa",
                        "flow": "",
                        "email": "saeka@404.local"
                    }
                ],
                "decryption": "none"
            },
            "streamSettings": {
                "network": "xhttp",
                "xhttpSettings": {
                    "path": "/saeka",
                    "mode": "packet-up",
                    "host": "",
                    "xmux": {
                        "maxConcurrency": "16-32"
                    },
                    "xPaddingBytes": "100-1000"
                },
                "sockopt": {
                    "tcpFastOpen": true,
                    "tcpNoDelay": true,
                    "tcpKeepAliveIdle": 30,
                    "tcpKeepAliveInterval": 15,
                    "tcpKeepAliveCount": 5
                }
            },
            "sniffing": {
                "enabled": true,
                "destOverride": ["http", "tls", "quic"]
            }
        }
    ],
    "outbounds": [
        {
            "tag": "DIRECT",
            "protocol": "freedom",
            "settings": {}
        }
    ]
}
